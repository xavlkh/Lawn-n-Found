<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Submit a Claim</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4" style="max-width: 640px;">
    <%- include('partials/messages') %>

    <h2 class="mb-3">Submit a Claim</h2>
    <p class="text-muted"><span class="text-danger">*</span> Required fields</p>

    <div class="card mb-3">
      <% if (report.image) { %>
        <img src="/images/<%= report.image %>" class="card-img-top" alt="<%= report.item_name %>" style="max-height: 300px; object-fit: contain;">
      <% } %>
      <div class="card-body">
        <h5 class="card-title"><%= report.item_name %></h5>
        <p class="card-text mb-1"><%= report.description %></p>
        <small class="text-muted">Type: <%= report.report_type %> | Status: <%= report.status %></small>
      </div>
    </div>

    <form action="/user/claims/submit/<%= report.report_id %>" method="POST" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="claim_message" class="form-label">
          Why is this item yours? (describe identifying details as proof) <span class="text-danger">*</span>
        </label>
        <textarea class="form-control" id="claim_message" name="claim_message" rows="4" required></textarea>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Proof Photo <span class="text-danger">*</span></label>
        <input
          type="file"
          id="image"
          name="image"
          class="form-control"
          accept="image/jpeg,image/png,image/gif,image/webp"
          required
        >
        <div class="form-text">Accepted formats: JPEG, PNG, GIF, WebP. Max 5 MB.</div>
      </div>

      <button type="submit" class="btn btn-primary">Submit Claim</button>
      <a href="/reports/<%= report.report_id %>" class="btn btn-outline-secondary">Cancel</a>
    </form>
    <div class="mb-4"></div>
  </div>
</body>
</html>
