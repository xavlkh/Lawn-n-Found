<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Lawn &amp; Found - Found Items</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <h2 class="mb-1">Found Items</h2>
    <p class="text-muted mb-4">Browse items that have been found on campus.</p>

    <% if (reports.length === 0) { %>
      <div class="alert alert-info">
        No found items reported yet.
      </div>
    <% } else { %>
      <div class="row">
        <% reports.forEach(report => { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100">
              <% if (report.image) { %>
                <img src="/images/<%= report.image || 'noImage.png' %>" alt="<%= report.item_name %>" class="card-img-top" style="height: 180px; object-fit: contain; background: white;">
              <% } %>
              <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <h5 class="card-title text-break mb-0"><%= report.item_name %></h5>
                  <span class="badge bg-<%= report.status === 'Resolved' ? 'secondary' : (report.status === 'Claimed' ? 'warning text-dark' : 'success') %>">
                    <%= report.status %>
                  </span>
                </div>
                <p class="card-text text-muted"><%= report.description %></p>

                <div class="mt-auto">
                  <% if (report.status === 'Resolved') { %>
                    <button class="btn btn-secondary btn-sm w-100" disabled>Resolved</button>
                  <% } else { %>
                    <a href="/user/claims/submit/<%= report.report_id %>" class="btn btn-primary btn-sm w-100">Submit Claim</a>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
    <div class="mb-4"></div>
  </div>
</body>
</html>
