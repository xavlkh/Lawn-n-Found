<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Manage Claims</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <h2 class="mb-1">Manage Claims</h2>
    <p class="text-muted mb-4">Review and manage user claims on found items.</p>

    <% if (claims.length === 0) { %>
      <div class="alert alert-info">
        No claims have been submitted yet.
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-bordered align-middle">
          <thead class="table-dark">
            <tr>
              <th>Item</th>
              <th>Claimed By</th>
              <th>Message</th>
              <th>Proof Image</th>
              <th>Status</th>
              <th>Submitted</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% claims.forEach(claim => { %>
              <tr>
                <td><%= claim.item_name %></td>
                <td><%= claim.username %><br><small class="text-muted"><%= claim.email %></small></td>
                <td><%= claim.claim_message %></td>
                <td>
                  <% if (claim.image) { %>
                    <a href="/images/<%= claim.image %>" target="_blank">
                      <img src="/images/<%= claim.image %>" alt="Proof" style="max-width: 80px; max-height: 80px; border-radius: 4px;">
                    </a>
                  <% } else { %>
                    <span class="text-muted">No image</span>
                  <% } %>
                </td>
                <td>
                  <span class="badge bg-<%= claim.status === 'Approved' ? 'success' : (claim.status === 'Rejected' ? 'danger' : 'warning text-dark') %>">
                    <%= claim.status %>
                  </span>
                </td>
                <td><%= new Date(claim.created_at).toLocaleString() %></td>
                <td>
                   <a href="/admin/claims/update/<%= claim.claim_id %>"
                    class="btn btn-warning btn-sm">
                      Update
                  </a>
                  <form action="/admin/claims/delete/<%= claim.claim_id %>"
                      method="POST"
                      style="display:inline;">
                    <button
                        type="submit"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Are you sure you want to delete this report?');">
                        Delete
                    </button>
                    </form>
                  <% if (claim.status === 'Pending') { %>
                    <form action="/admin/claims/<%= claim.claim_id %>/approve" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-success btn-sm">Approve</button>
                    </form>
                    <form action="/admin/claims/<%= claim.claim_id %>/reject" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <div class="mb-4"></div>
  </div>
</body>
</html>
