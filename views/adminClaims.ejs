<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Manage Claims | Lawn & Found</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <h2 class="mb-1">Manage Claims</h2>
    <p class="text-muted mb-4">Review and manage user claims on found items.</p>

    <% if (claims.length === 0) { %>
      <div class="alert alert-info">
        No claims have been submitted yet.
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-bordered align-middle">
          <thead class="table-dark">
            <tr>
              <th>Item</th>
              <th>Claimed By</th>
              <th>Message</th>
              <th>Proof Image</th>
              <th>Status</th>
              <th>Submitted</th>
              <th>Reason</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% claims.forEach(claim => { %>
              <tr>
                <td>
                  <% if (claim.report_image) { %>
                    <a href="/images/<%= claim.report_image %>" target="_blank">
                      <img src="/images/<%= claim.report_image %>" alt="<%= claim.item_name %>" style="max-width: 80px; max-height: 80px; border-radius: 4px;" class="d-block mb-1">
                    </a>
                  <% } %>
                  <%= claim.item_name %>
                </td>
                <td><%= claim.username %><br><small class="text-muted"><%= claim.email %></small></td>
                <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= claim.claim_message %>"><%= claim.claim_message %></td>
                <td>
                  <% if (claim.image) { %>
                    <a href="/images/<%= claim.image %>" target="_blank">
                      <img src="/images/<%= claim.image %>" alt="Proof" style="max-width: 80px; max-height: 80px; border-radius: 4px;">
                    </a>
                  <% } else { %>
                    <span class="text-muted">No image</span>
                  <% } %>
                </td>
                <td>
                  <span class="badge bg-<%= claim.status === 'Approved' ? 'success' : (claim.status === 'Rejected' ? 'danger' : 'warning text-dark') %>">
                    <%= claim.status %>
                  </span>
                </td>
                <td><%= new Date(claim.created_at).toLocaleString('en-SG', { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }) %></td>
                <td>
                  <% if (claim.status === 'Pending') { %>
                    <form action="/admin/claims/<%= claim.claim_id %>/approve" method="POST" class="mb-2">
                      <button type="submit" class="btn btn-success btn-sm">Approve</button>
                    </form>
                    <form action="/admin/claims/<%= claim.claim_id %>/reject" method="POST">
                      <label for="reject_reason_<%= claim.claim_id %>" class="form-label small text-muted mb-1">Rejection reason (optional)</label>
                      <input type="text" id="reject_reason_<%= claim.claim_id %>" name="reject_reason" class="form-control form-control-sm text-truncate" placeholder="e.g. Insufficient proof" style="max-width: 100%; overflow: hidden; text-overflow: ellipsis;">
                      <button type="submit" class="btn btn-danger btn-sm mt-1">Reject</button>
                    </form>
                  <% } else if (claim.status === 'Rejected') { %>
                    <% if (claim.reject_reason) { %>
                      <span class="text-danger small"><%= claim.reject_reason %></span>
                    <% } else { %>
                      <span class="text-muted small fst-italic">No reason provided</span>
                    <% } %>
                  <% } else if (claim.status === 'Approved') { %>
                    <span class="text-success small fst-italic">Report resolved</span>
                  <% } %>
                </td>
                <td>
                    <div class="d-flex flex-wrap gap-2">

                        <a href="/admin/claims/update/<%= claim.claim_id %>"
                          class="btn btn-warning btn-sm">
                            Update
                        </a>

                        <form action="/admin/claims/delete/<%= claim.claim_id %>"
                              method="POST"
                              class="m-0">
                            <button type="submit"
                                    class="btn btn-danger btn-sm"
                                    onclick="return confirm('Are you sure you want to delete this claim?');">
                                Delete
                            </button>
                        </form>

                    </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <div class="mb-4 pb-4"></div>
  </div>
</body>
</html>
