<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Manage Claims</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <h2 class="mb-3">Manage Claims (Admin)</h2>

    <% if (claims.length === 0) { %>
      <p>No claims have been submitted yet.</p>
    <% } else { %>
      <table class="table table-bordered align-middle">
        <thead class="table-dark">
          <tr>
            <th>Item</th>
            <th>Claimed By</th>
            <th>Message</th>
            <th>Status</th>
            <th>Submitted</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% claims.forEach(claim => { %>
            <tr>
              <td><%= claim.item_name %></td>
              <td><%= claim.username %><br><small class="text-muted"><%= claim.email %></small></td>
              <td><%= claim.claim_message %></td>
              <td>
                <span class="badge bg-<%= claim.status === 'Approved' ? 'success' : (claim.status === 'Rejected' ? 'danger' : 'warning text-dark') %>">
                  <%= claim.status %>
                </span>
              </td>
              <td><%= new Date(claim.created_at).toLocaleString() %></td>
              <td>
                <% if (claim.status === 'Pending') { %>
                  <form action="/admin/claims/<%= claim.claim_id %>/approve" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-success btn-sm">Approve</button>
                  </form>
                  <form action="/admin/claims/<%= claim.claim_id %>/reject" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                  </form>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
