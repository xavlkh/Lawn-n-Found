<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Manage Claims</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <h2 class="mb-1">Manage Claims</h2>
    <p class="text-muted mb-4">Review and manage user claims on found items.</p>

    <% if (claims.length === 0) { %>
      <div class="alert alert-info">
        No claims have been submitted yet.
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-bordered align-middle">
          <thead class="table-dark">
            <tr>
              <th>Item</th>
              <th>Claimed By</th>
              <th>Message</th>
              <th>Proof Image</th>
              <th>Status</th>
              <th>Submitted</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% claims.forEach(claim => { %>
              <tr>
                <td>
                  <% if (claim.report_image) { %>
                    <a href="/images/<%= claim.report_image %>" target="_blank">
                      <img src="/images/<%= claim.report_image %>" alt="<%= claim.item_name %>" style="max-width: 80px; max-height: 80px; border-radius: 4px;" class="d-block mb-1">
                    </a>
                  <% } %>
                  <%= claim.item_name %>
                </td>
                <td><%= claim.username %><br><small class="text-muted"><%= claim.email %></small></td>
                <td><%= claim.claim_message %></td>
                <td>
                  <% if (claim.image) { %>
                    <a href="/images/<%= claim.image %>" target="_blank">
                      <img src="/images/<%= claim.image %>" alt="Proof" style="max-width: 80px; max-height: 80px; border-radius: 4px;">
                    </a>
                  <% } else { %>
                    <span class="text-muted">No image</span>
                  <% } %>
                </td>
                <td>
                  <span class="badge bg-<%= claim.status === 'Approved' ? 'success' : (claim.status === 'Rejected' ? 'danger' : 'warning text-dark') %>">
                    <%= claim.status %>
                  </span>
                </td>
                <td><%= new Date(claim.created_at).toLocaleString() %></td>
                <td>
                  <% if (claim.status === 'Pending') { %>
                    <form action="/admin/claims/<%= claim.claim_id %>/approve" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-success btn-sm">Approve</button>
                    </form>
                    <form action="/admin/claims/<%= claim.claim_id %>/reject" method="POST" style="min-width: 160px;">
                      <input type="text" name="reject_reason" class="form-control form-control-sm mt-1" placeholder="Reason (optional)">
                      <button type="submit" class="btn btn-danger btn-sm mt-1">Reject</button>
                    </form>
                  <% } else if (claim.status === 'Rejected') { %>
                    <span class="text-danger small">
                      <%= claim.reject_reason ? claim.reject_reason : 'No reason provided' %>
                    </span>
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <div class="mb-4"></div>
  </div>
</body>
</html>
