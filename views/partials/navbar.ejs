<!-- Role-based navigation. Only links to pages that exist in this
     Part E demo; the full navbar is a shared/Part A concern. -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
  <div class="container">
    <a class="navbar-brand p-0" href="/">
      <img src="/images/lawn-and-found-navbar-logo.svg" alt="Lawn &amp; Found" height="42">
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="collapsibleNavbar">

      <ul class="navbar-nav ms-auto" style="--bs-scroll-height: 100px;">

          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>

          <% if (user) { %>
              <% if (user.role === 'user') { %>
                <li class="nav-item">
                  <a class="nav-link" href="/reports/new">Create Report</a>
                </li>
              <% } %>
          <% var navTotal = (user.role === 'admin' ? pendingClaims : pendingAlerts); %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle text-info" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              Hi, <%= user.username %>
              <% if (navTotal > 0) { %>
                <span class="badge bg-danger rounded-pill"><%= navTotal %></span>
              <% } %>
            </a>
            <ul class="dropdown-menu">
                      <% if (user.role === 'admin') { %>
                            <li>
                              <a class="dropdown-item d-flex justify-content-between align-items-center" href="/admin/claims">
                                Manage Claims
                                <% if (pendingClaims > 0) { %><span class="badge bg-danger rounded-pill"><%= pendingClaims %></span><% } %>
                              </a>
                            </li>
                            <li><a class="dropdown-item" href="/admin/users">Manage Users</a></li>
                      <% } else { %>
                            <li><a class="dropdown-item" href="/user/reports">My Reports</a></li>
                            <li>
                              <a class="dropdown-item d-flex justify-content-between align-items-center" href="/user/lost-item-alerts">
                                Lost Item Alerts
                                <% if (pendingAlerts > 0) { %><span class="badge bg-danger rounded-pill ms-2"><%= pendingAlerts %></span><% } %>
                              </a>
                            </li>
                            <li><a class="dropdown-item" href="/user/claims">My Claims</a></li>
                      <% } %>
                      <li><hr class="dropdown-divider"></li>
                      <li><a class="dropdown-item" href="/logout">Logout</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/login">Login</a>
          </li>
        <% } %>
        </ul>
        

    </div>
  </div>
</nav>
<div style="height: 56px;"></div>