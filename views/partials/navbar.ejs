<!-- Role-based navigation. Only links to pages that exist in this
     Part E demo; the full navbar is a shared/Part A concern. -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/">Lawn &amp; Found</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav ms-auto">

        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>
        
        <% if (user) { %>
          <% if (user.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin/claims">Manage Claims</a>
            </li>  
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/claims/my">My Claims</a>
            </li>
          <% } %>

            <li class="nav-item">
              <span class="nav-link text-info">Hi, <%= user.username %></span>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/logout">Logout</a>
            </li>

        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/register">Register</a>
          </li>
          
          <li class="nav-item">
            <a class="nav-link" href="/login">Login</a>
          </li>
        <% } %>

      </ul>
    </div>
  </div>
</nav>
