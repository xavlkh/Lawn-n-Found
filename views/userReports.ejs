<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>My Reports | Lawn & Found</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <div class="mb-4">
      <h2 class="mb-1">My Reports</h2>
      <p class="text-muted mb-0">
        Reports you have submitted.
      </p>
    </div>

    <% if (reports.length === 0) { %>
      <div class="alert alert-info">
        You have not created any reports yet.
        <a href="/reports/new" class="alert-link">
          Create your first report
        </a>.
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped align-middle">
          <thead>
            <tr>
              <th>Item</th>
              <th>Image</th>
              <th>Type</th>
              <th>Category</th>
              <th>Location</th>
              <th>Status</th>
              <th>Date</th>
              <th>Action</th>
            </tr>
          </thead>

          <tbody>
            <% reports.forEach(report => { %>
              <tr>
                <td class="item-name-cell" title="<%= report.item_name %>"><%= report.item_name %></td>

                <td>
                  <% if (report.image) { %>
                    <a href="/images/<%= report.image %>" target="_blank">
                      <img src="/images/<%= report.image %>" alt="<%= report.item_name %>" style="max-width: 70px; max-height: 70px; border-radius: 4px;">
                    </a>
                  <% } else { %>
                    <span class="text-muted">No image</span>
                  <% } %>
                </td>

                <td>
                  <span class="badge bg-<%= report.report_type === 'Lost' ? 'danger' : 'success' %>">
                    <%= report.report_type %>
                  </span>
                </td>

                <td><%= report.category_name || 'Not specified' %></td>

                <td><%= report.location_name || 'Not specified' %></td>

                <td>
                  <span
                    class="badge bg-<%= report.status === 'Resolved'
                      ? 'secondary'
                      : 'primary' %>"
                  >
                   <%= report.status %>
                  </span>
                </td>

                <td>
                  <%= new Date(report.date_lost_found).toLocaleDateString('en-SG', { day: '2-digit', month: '2-digit', year: '2-digit' }) %>
                </td>

                <td style="min-width: 80px;">
                    <div class="d-flex flex-wrap gap-1">

                        <!-- Always available -->
                        <a href="/reports/<%= report.report_id %>"
                          class="btn btn-primary btn-sm">
                            View
                        </a>

                        <% if (report.status === 'Open') { %>

                            <a href="/update/<%= report.report_id %>"
                              class="btn btn-warning btn-sm">
                                Update
                            </a>

                            <form action="/reports/delete/<%= report.report_id %>"
                                  method="POST"
                                  class="m-0">
                                <button
                                    type="submit"
                                    class="btn btn-danger btn-sm"
                                    onclick="return confirm('Are you sure you want to delete this report?');">
                                    Delete
                                </button>
                            </form>

                            <% if (report.report_type === 'Lost') { %>

                                <form action="/reports/<%= report.report_id %>/mark-recovered"
                                      method="POST"
                                      class="m-0">
                                    <button
                                        type="submit"
                                        class="btn btn-success btn-sm"
                                        onclick="return confirm('Confirm that you have recovered this item?');">
                                        Mark Recovered
                                    </button>
                                </form>

                            <% } %>

                        <% } %>

                    </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <div class="mb-4 pb-4"></div>
  </div>
</body>
</html>