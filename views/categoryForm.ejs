<!DOCTYPE html>
<html lang="en">
    <head>
        <%- include('partials/head') %>
        <title><%= isEdit ? "Update Category" : "Add Category" %></title>
    </head>
    <body>

        <%- include('partials/navbar') %>

        <div class="container mt-4">
            <%- include('partials/messages') %>

        <h2><%= isEdit ? "Update Category" : "Add Category" %></h2>

        <form action="<%= isEdit ? '/admin/categories/update/' + category.category_id : '/admin/categories/add' %>"
            method="POST">

            <div class="mb-3">

                <label class="form-label">Category Name</label>

                <input
                    type="text"
                    name="name"
                    class="form-control"
                    value="<%= isEdit ? category.name : '' %>"
                    required>

            </div>

            <button class="btn btn-primary">
                <%= isEdit ? "Update Category" : "Add Category" %>
            </button>

            <a href="/admin/categories" class="btn btn-secondary">
                Cancel
            </a>

        </form>
    </body>
</html>