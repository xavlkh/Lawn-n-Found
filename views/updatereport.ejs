<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Update Report | Lawn & Found</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('partials/navbar') %>

<div class="container mt-4" style="max-width:700px;">
    <%- include('partials/messages') %>

    <h2>Update Report</h2>
    <p class="text-muted"><span class="text-danger">*</span> Required fields</p>

    <form action="/update/<%= report.report_id %>" method="POST" enctype="multipart/form-data">

        <input type="hidden" name="report_id" value="<%= report.report_id %>">

        <!-- Report Type -->
        <div class="mb-3">
            <label class="form-label">Report Type <span class="text-danger">*</span></label>
            <select name="report_type" class="form-select" required>
                <option value="Lost" <%= report.report_type=="Lost" ? "selected" : "" %>>Lost</option>
                <option value="Found" <%= report.report_type=="Found" ? "selected" : "" %>>Found</option>
            </select>
        </div>

        <!-- Item Name -->
        <div class="mb-3">
            <label class="form-label">Item Name <span class="text-danger">*</span></label>
            <input
                type="text"
                name="item_name"
                class="form-control"
                maxlength="150"
                value="<%= report.item_name %>"
                required>
        </div>

        <!-- Description -->
        <div class="mb-3">
            <label class="form-label">Description <span class="text-danger">*</span></label>
            <textarea
                name="description"
                class="form-control"
                rows="4"
                required><%= report.description %></textarea>
        </div>

        <!-- Category -->
        <div class="mb-3">
            <label class="form-label">Category <span class="text-danger">*</span></label>
            <select name="category_id" class="form-select" required>
                <% categories.forEach(category => { %>
                    <option value="<%= category.category_id %>"
                        <%= category.category_id == report.category_id ? "selected" : "" %>>
                        <%= category.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- Location -->
        <div class="mb-3">
            <label class="form-label">Location <span class="text-danger">*</span></label>
            <select name="location_id" class="form-select" required>
                <% locations.forEach(location => { %>
                    <option value="<%= location.location_id %>"
                        <%= location.location_id == report.location_id ? "selected" : "" %>>
                        <%= location.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- Date -->
        <div class="mb-3">
            <label class="form-label">Date Lost or Found <span class="text-danger">*</span></label>
            <input
                type="date"
                name="date_lost_found"
                class="form-control"
                value="<%= report.date_lost_found.toISOString().split('T')[0] %>"
                max="<%= today %>"
                required>
        </div>

        <!-- Current Image -->
        <% if(report.image){ %>
        <div class="mb-3">
            <label class="form-label">Current Image</label><br>
            <img src="/images/<%= report.image %>"
                 class="img-thumbnail"
                 width="200">
        </div>
        <% } %>

        <!-- New Image -->
        <div class="mb-3">
            <label class="form-label">Replace Image</label>
            <input
                type="file"
                name="image"
                class="form-control"
                accept="image/jpeg,image/png,image/gif,image/webp">
            <div class="form-text">
                Leave empty if you don't want to change the image.
            </div>
        </div>

        <button type="submit" class="btn btn-warning">
            Update Report
        </button>

        <a href="/" class="btn btn-secondary">
            Cancel
        </a>

    </form>
    <div class="mb-4 pb-4"></div>
</div>

</body>
</html>