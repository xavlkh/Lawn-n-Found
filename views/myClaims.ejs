<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>My Claims</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <h2 class="mb-3">My Claims</h2>

    <% if (claims.length === 0) { %>
      <p>You have not submitted any claims yet. <a href="/">Browse found items</a>.</p>
    <% } else { %>
      <table class="table table-striped align-middle">
        <thead>
          <tr>
            <th>Item</th>
            <th>Your Message</th>
            <th>Status</th>
            <th>Submitted</th>
          </tr>
        </thead>
        <tbody>
          <% claims.forEach(claim => { %>
            <tr>
              <td><%= claim.item_name %></td>
              <td><%= claim.claim_message %></td>
              <td>
                <span class="badge bg-<%= claim.status === 'Approved' ? 'success' : (claim.status === 'Rejected' ? 'danger' : 'warning text-dark') %>">
                  <%= claim.status %>
                </span>
              </td>
              <td><%= new Date(claim.created_at).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
