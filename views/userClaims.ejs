<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>My Claims</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <h2 class="mb-1">My Claims</h2>
    <p class="text-muted mb-4">Claims you have submitted on found items.</p>

    <% if (claims.length === 0) { %>
      <div class="alert alert-info">
        You have not submitted any claims yet.
        <a href="/" class="alert-link">Browse found items</a>.
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped align-middle">
          <thead>
            <tr>
              <th>Item</th>
              <th>Item Image</th>
              <th>Your Message</th>
              <th>Proof Image</th>
              <th>Status</th>
              <th>Submitted</th>
            </tr>
          </thead>
          <tbody>
            <% claims.forEach(claim => { %>
              <tr>
                <td><%= claim.item_name %></td>
                <td>
                  <% if (claim.report_image) { %>
                    <a href="/images/<%= claim.report_image %>" target="_blank">
                      <img src="/images/<%= claim.report_image %>" alt="<%= claim.item_name %>" style="max-width: 80px; max-height: 80px; border-radius: 4px;">
                    </a>
                  <% } else { %>
                    <span class="text-muted">No image</span>
                  <% } %>
                </td>
                <td><%= claim.claim_message %></td>
                <td>
                  <% if (claim.image) { %>
                    <a href="/images/<%= claim.image %>" target="_blank">
                      <img src="/images/<%= claim.image %>" alt="Proof" style="max-width: 80px; max-height: 80px; border-radius: 4px;">
                    </a>
                  <% } else { %>
                    <span class="text-muted">No image</span>
                  <% } %>
                </td>
                <td>
                  <span class="badge bg-<%= claim.status === 'Approved' ? 'success' : (claim.status === 'Rejected' ? 'danger' : 'warning text-dark') %>">
                    <%= claim.status %>
                  </span>
                  <% if (claim.status === 'Rejected' && claim.reject_reason) { %>
                    <div class="small text-muted mt-1">Reason: <%= claim.reject_reason %></div>
                  <% } %>
                </td>
                <td><%= new Date(claim.created_at).toLocaleString('en-SG', { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <div class="mb-4"></div>
  </div>
</body>
</html>
