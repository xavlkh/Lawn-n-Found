<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Browse Reports</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-1">Lost and Found Reports</h2>
        <p class="text-muted mb-0">
          Browse items reported by campus users.
        </p>
      </div>

      <% if (user) { %>
        <a href="/reports/new" class="btn btn-primary">
          Create Report
        </a>
      <% } %>
    </div>

    <% if (reports.length === 0) { %>
      <div class="alert alert-info">
        No lost or found reports have been submitted.
      </div>
    <% } else { %>
      <div class="row">
        <% reports.forEach(report => { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100">
              <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between mb-2">
                  <span class="badge bg-<%= report.report_type === 'Lost' ? 'danger' : 'success' %>">
                    <%= report.report_type %>
                  </span>

                  <span class="badge bg-<%= report.status === 'Resolved' ? 'secondary' : (report.status === 'Claimed' ? 'warning text-dark' : 'primary') %>">
                    <%= report.status %>
                  </span>
                </div>

                <h5 class="card-title"><%= report.item_name %></h5>

                <p class="card-text">
                  <%= report.description.length > 100
                    ? report.description.substring(0, 100) + '...'
                    : report.description %>
                </p>

                <div class="small text-muted mb-3">
                  <div>
                    <strong>Category:</strong>
                    <%= report.category_name || 'Not specified' %>
                  </div>

                  <div>
                    <strong>Location:</strong>
                    <%= report.location_name || 'Not specified' %>
                  </div>

                  <div>
                    <strong>Date:</strong>
                    <%= new Date(report.date_lost_found).toLocaleDateString('en-SG') %>
                  </div>

                  <div>
                    <strong>Reported by:</strong>
                    <%= report.reporter_name || 'Unknown user' %>
                  </div>
                </div>

                <a
                  href="/reports/<%= report.report_id %>"
                  class="btn btn-outline-primary mt-auto"
                >
                  View Details
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>