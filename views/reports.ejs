<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Browse Reports | Lawn & Found</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <%- include('partials/messages') %>

    <header class="text-center py-3 mb-3">
      <h1 class="display-5 fw-bold mb-3">Lost and Found Reports</h1>
      <p class="fs-5 text-secondary mb-0">
        Browse lost and found reports. Search by keyword and use filters to narrow your results.
      </p>
    </header>

    <!-- ==============================================================
         PART D (May) - FILTER FORM
    =============================================================== -->
    <form action="/" method="POST" class="mb-4">
      <!-- PART D - search bar row (May) -->
      <div class="d-flex align-items-center gap-2 mb-2">
        <div class="card card-body flex-grow-1">
          <div class="d-flex align-items-center gap-2">
            <input type="text" class="form-control" id="searchText" name="searchText"
                   placeholder="Search items e.g. keys, wallet, phone" value="<%= filters.searchText %>"
                   style="text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
            <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-1"
                    id="filterToggleBtn" data-bs-toggle="collapse" data-bs-target="#filterPanel"
                    aria-expanded="<%= filters.report_type || filters.category_id || filters.location_id || (filters.status && filters.status !== 'Open') ? 'true' : 'false' %>"
                    aria-controls="filterPanel">
              <i class="bi bi-funnel"></i> Filters
              <% if (filters.report_type || filters.category_id || filters.location_id || (filters.status && filters.status !== 'Open')) { %>
                <span class="badge bg-primary rounded-pill">Active</span>
              <% } %>
            </button>
            <button type="submit" class="btn btn-primary">Search</button>
          </div>
        </div>
      </div>

      <!-- PART D - filter dropdown panel (May) -->
      <div class="collapse <%= filters.report_type || filters.category_id || filters.location_id || (filters.status && filters.status !== 'Open') ? 'show' : '' %>" id="filterPanel">
        <div class="card card-body">
          <div class="row g-3">
            <!-- PART D - filter type (May) -->
            <div class="col-md-2">
              <label for="report_type" class="form-label">Type</label>
              <select class="form-select" id="report_type" name="report_type">
                <option value="">All</option>
                <option value="Lost"  <%= filters.report_type === 'Lost'  ? 'selected' : '' %>>Lost</option>
                <option value="Found" <%= filters.report_type === 'Found' ? 'selected' : '' %>>Found</option>
              </select>
            </div>

            <!-- PART D - categories (May) -->
            <div class="col-md-3">
              <label for="category_id" class="form-label">Category</label>
              <select class="form-select" id="category_id" name="category_id">
                <option value="">All</option>
                <% categories.forEach(category => { %>
                  <option value="<%= category.category_id %>"
                    <%= String(filters.category_id) === String(category.category_id) ? 'selected' : '' %>>
                    <%= category.name %>
                  </option>
                <% }); %>
              </select>
            </div>

            <!-- PART D - filter location (May) -->
            <div class="col-md-3">
              <label for="location_id" class="form-label">Location</label>
              <select class="form-select" id="location_id" name="location_id">
                <option value="">All</option>
                <% locations.forEach(location => { %>
                  <option value="<%= location.location_id %>"
                    <%= String(filters.location_id) === String(location.location_id) ? 'selected' : '' %>>
                    <%= location.name %>
                  </option>
                <% }); %>
              </select>
            </div>

            <!-- PART D - filter status (May) -->
            <div class="col-md-2">
              <label for="status" class="form-label">Status</label>
              <select class="form-select" id="status" name="status">
                <option value="">All</option>
                <option value="Open"     <%= filters.status === 'Open'     ? 'selected' : '' %>>Open</option>
                <option value="Resolved" <%= filters.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
              </select>
            </div>

            <!-- PART D - sort (May) -->
            <div class="col-md-2">
              <label for="sort" class="form-label">Sort By</label>
              <select class="form-select" id="sort" name="sort">
                <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
                <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
              </select>
            </div>
          </div>

          <div class="mt-3 d-flex justify-content-end">
            <a href="/" class="btn btn-outline-secondary btn-sm">Clear All Filters</a>
          </div>
        </div>
      </div>
    </form>
    <!-- END OF PART D (May) -->

    <!-- PART D - result count (May) -->
    <p class="text-muted"><%= reports.length %> report(s) found.</p>

    <% if (reports.length === 0) { %>
      <div class="alert alert-info">
        No reports match your search. Try different keywords or clear the filters.
      </div>
    <% } else { %>
      <div class="row">
        <% reports.forEach(report => { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100">
              <% if (report.image) { %>
                <img src="/images/<%= report.image %>" alt="<%= report.item_name %>" class="card-img-top" style="height: 180px; object-fit: contain; background: white;">
              <% } %>
              <div class="card-body d-flex flex-column">
                <h5 class="card-title text-break"><%= report.item_name %></h5>

                <div class="mb-3">
                  <span class="badge rounded-pill bg-<%= report.report_type === 'Lost' ? 'danger' : 'success' %> me-1">
                    <%= report.report_type %>
                  </span>
                  <span class="badge rounded-pill bg-<%= report.status === 'Resolved' ? 'secondary' : 'primary' %>">
                    <%= report.status %>
                  </span>
                </div>

                <p class="card-text text-muted">
                  <%= report.description.length > 100
                    ? report.description.substring(0, 100) + '...'
                    : report.description %>
                </p>

                <div class="mt-auto d-grid gap-2">
                  <a
                    href="/reports/<%= report.report_id %>"
                    class="btn btn-primary report-details-btn"
                  >
                    View Details
                  </a>

                  <% if (
                    user &&
                    user.role !== 'admin' &&
                    report.status === 'Open' &&
                    report.report_type === 'Found' &&
                    user.user_id !== report.user_id
                  ) { %>
                    <% if (claimedReportIds && claimedReportIds.includes(report.report_id)) { %>
                      <button class="btn btn-outline-warning" disabled>Claim Submitted</button>
                    <% } else { %>
                      <a
                        href="/user/claims/submit/<%= report.report_id %>"
                        class="btn btn-warning"
                      >
                        Claim This Item
                      </a>
                    <% } %>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
    <div class="mb-4"></div>
  </div>
</body>
</html>
