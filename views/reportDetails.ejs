<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title><%= report.item_name %> - Report Details</title>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4" style="max-width: 800px;">
    <%- include('partials/messages') %>

    <a href="/" class="btn btn-outline-secondary btn-sm mb-3">
      Back to Reports
    </a>

    <div class="card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <h2 class="card-title mb-1"><%= report.item_name %></h2>

            <span class="badge bg-<%= report.report_type === 'Lost' ? 'danger' : 'success' %>">
              <%= report.report_type %>
            </span>
          </div>

          <span class="badge bg-<%= report.status === 'Resolved' ? 'secondary' : (report.status === 'Claimed' ? 'warning text-dark' : 'primary') %>">
            <%= report.status %>
          </span>
        </div>

        <dl class="row">
          <dt class="col-sm-4">Description</dt>
          <dd class="col-sm-8"><%= report.description %></dd>

          <dt class="col-sm-4">Category</dt>
          <dd class="col-sm-8">
            <%= report.category_name || 'Not specified' %>
          </dd>

          <dt class="col-sm-4">Location</dt>
          <dd class="col-sm-8">
            <%= report.location_name || 'Not specified' %>
          </dd>

          <dt class="col-sm-4">Date Lost or Found</dt>
          <dd class="col-sm-8">
            <%= new Date(report.date_lost_found).toLocaleDateString('en-SG') %>
          </dd>

          <dt class="col-sm-4">Reported By</dt>
          <dd class="col-sm-8">
            <%= report.reporter_name || 'Unknown user' %>
          </dd>

          <dt class="col-sm-4">Created</dt>
          <dd class="col-sm-8">
            <%= new Date(report.created_at).toLocaleString('en-SG') %>
          </dd>
        </dl>

        <% if (
          user &&
          report.report_type === 'Found' &&
          report.status !== 'Resolved' &&
          user.id !== report.user_id
        ) { %>
          <a
            href="/claims/submit/<%= report.report_id %>"
            class="btn btn-primary"
          >
            Submit Claim
          </a>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>